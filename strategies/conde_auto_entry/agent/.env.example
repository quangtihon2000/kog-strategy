# Required ---------------------------------------------------------------

# Absolute path to the directory where {account}_{symbol}.json files are written.
# For local development use the data/ folder at the project root.
# For production point this at the MT5 common Files folder.
#   Windows: C:\Users\You\AppData\Roaming\MetaQuotes\Terminal\Common\Files
#   macOS/Wine: /home/user/.wine/drive_c/users/user/Application Data/MetaQuotes/...
MT5_SIGNAL_DIR=../data

# Comma-separated list of MT5 account numbers to write signal files for
MT5_ACCOUNTS=5100000,5100001

# Comma-separated list of symbols to write signal files for
MT5_SYMBOLS=XAUUSD,EURUSD

# Optional ---------------------------------------------------------------

REDIS_URL=redis://localhost:6379
REDIS_STREAM=conde_signals
REDIS_GROUP=conde_writer
REDIS_CONSUMER=conde-agent-1
LOG_LEVEL=INFO

# Phase 3 — per-account channel gate ------------------------------------
# Per-account filter lives in config/accounts/<account>.json:
#   "conde_channel_filter": "off" | "approved" | "list"
#   "conde_channel_allowlist": [ -1001234567890, ... ]   (used when "list")
# These envs only control the "approved" source + refresh cadence.

# Where the agent reads per-account configs (defaults to the repo path).
# CONDE_ACCOUNT_CONFIG_DIR=../config/accounts

# strategy-stats endpoint serving the ranked quality list (Phase 2).
STATS_QUALITY_URL=https://stats.auto-trade.life/conde/quality.json

# How often (seconds) to refresh the approved set in the background.
APPROVED_REFRESH_SEC=300
