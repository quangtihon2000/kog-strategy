# Required
TELEGRAM_BOT_TOKEN=123456789:AA-replace-with-BotFather-token
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Optional — where monitor alerts fan out. User ids (DM) or group/channel
# ids (negative, e.g. -1001234567890). Empty = falls back to ALLOWED_USER_IDS.
# TELEGRAM_ALERT_CHAT_IDS=-1001234567890

# Optional (defaults shown)
# REDIS_URL=redis://localhost:6379
# LOG_LEVEL=INFO
# FLEET_CONFIG=./fleet.yaml
