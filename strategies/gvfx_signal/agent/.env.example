# Required ---------------------------------------------------------------

# Absolute path to the directory where {account}_{symbol}.json files are written.
# For local development use the data/ folder at the project root.
# For production point this at the MT5 Files folder (per-terminal):
#   Windows: C:\Users\You\AppData\Roaming\MetaQuotes\Terminal\{hash}\MQL5\Files\GvfxSignalEA
MT5_SIGNAL_DIR=../data

# Comma-separated list of MT5 account numbers to write signal files for
MT5_ACCOUNTS=5100000

# Comma-separated list of symbols to write signal files for
MT5_SYMBOLS=XAUUSD

# Optional ---------------------------------------------------------------

REDIS_URL=redis://localhost:6379
REDIS_STREAM=gvfx_signals
REDIS_GROUP=gvfx_writer
REDIS_CONSUMER=gvfx-agent-1
LOG_LEVEL=INFO
