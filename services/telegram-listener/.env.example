# Copy to .env and fill in. See specs/telegram-signal-listener.md section 5.1.

# Telethon credentials — get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Session file basename + persistent dir (mount as volume in prod)
TELEGRAM_SESSION_NAME=kog_signals
TELEGRAM_SESSION_DIR=/data/sessions

# Path to channels.yaml (channel + parser + LLM config)
SIGNAL_CHANNELS_CONFIG=/etc/kog/channels.yaml

# Redis Streams output
REDIS_URL=redis://redis:6379/0

# LLM provider for Tier 3 fallback extractor
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Logging
LOG_LEVEL=INFO

# Drop messages older than this when service starts (avoid replay storm)
STARTUP_REPLAY_WINDOW_MIN=1
