# Postgres
POSTGRES_USER=stats
POSTGRES_PASSWORD=changeme
POSTGRES_DB=strategy_stats
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Upstream Redis (MT5 VPS). Production: rediss:// with requirepass.
# Local dev: redis://host.docker.internal:6379
# Production: rediss://default:<password>@<mt5-vps-host>:6380
UPSTREAM_REDIS_URL=redis://host.docker.internal:6379

# Stream namespace prefix (empty = production names like "conde_signals";
# set to "dev_" / "test_" for staging to avoid colliding with prod streams).
REDIS_STREAM_PREFIX=

# Basic auth (single shared credential)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=changeme

# Web
WEB_PORT=8080

# Caddy reverse-proxy domain (production). Leave blank for local-only.
DASHBOARD_DOMAIN=stats.example.com

# Ingest tuning
INGEST_BATCH_COUNT=64
INGEST_BLOCK_MS=5000
INGEST_CONSUMER_NAME=stats-worker-1
