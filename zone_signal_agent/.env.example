# Required ---------------------------------------------------------------

# Absolute path to the MT5 common Files folder (or any directory the EA reads)
# Windows example: C:\Users\You\AppData\Roaming\MetaQuotes\Terminal\Common\Files
# macOS/Wine example: /home/user/.wine/drive_c/users/user/Application Data/...
MT5_SIGNAL_DIR=/path/to/MetaTrader5/MQL5/Files

# Comma-separated list of MT5 account numbers to write signal files for
MT5_ACCOUNTS=5100000,5100001

# Optional ---------------------------------------------------------------

REDIS_URL=redis://localhost:6379
REDIS_STREAM=zone_signals
REDIS_GROUP=ea_writer
REDIS_CONSUMER=agent-1
LOG_LEVEL=INFO
